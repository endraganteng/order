# ============================================================================
# Order app — production .env template
# ============================================================================
# Salin file ini sebagai .env di VPS, lalu isi dengan nilai production.
# JANGAN commit .env ke git.
#
#   cp .env.docker.example .env
#   nano .env
#
# Untuk Hermes / setup automation: file .env harus ada di /var/www/order/.env
# di VPS sebelum `docker compose up`.
# ============================================================================

# === Application ===
APP_NAME="Order"
APP_ENV=production
APP_KEY=                                    # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://${APP_DOMAIN}
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file

# === Domain (dipakai Traefik untuk routing) ===
APP_DOMAIN=order.example.com               # Ganti dengan domain Anda

# === Database (MySQL container shared di VPS) ===
DB_CONNECTION=mysql
DB_HOST=mysql                              # Nama service MySQL di network "db"
DB_PORT=3306
DB_DATABASE=order_app
DB_USERNAME=order_app
DB_PASSWORD=                               # Set di VPS, jangan commit

# === Cache / Session / Queue (file-driver, no Redis dependency) ===
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# === Logging ===
LOG_CHANNEL=stderr                         # Container-friendly: log ke stdout/stderr
LOG_LEVEL=warning                          # Production: warning ke atas saja

# === Firebase ===
# Path container ke credentials JSON. File di-mount dari host (lihat
# FIREBASE_CREDENTIALS_HOST_PATH di bawah).
FIREBASE_CREDENTIALS=/var/www/html/storage/firebase-credentials.json
FIREBASE_CREDENTIALS_HOST_PATH=/var/www/order/secrets/firebase-credentials.json
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_URL=

# === Gemini (AI product chat) ===
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash-exp
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# === Supabase (vector DB untuk product knowledge) ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VECTOR_TABLE=product_vectors

# === Fonnte (WhatsApp notification) ===
FONNTE_TOKEN=
FONNTE_DEVICE=

# === DANA payment ===
DANA_MERCHANT_ID=
DANA_PRIVATE_KEY=
DANA_PUBLIC_KEY=
DANA_API_URL=

# === Mail (kalau dipakai) ===
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@${APP_DOMAIN}"
MAIL_FROM_NAME="${APP_NAME}"

# === Admin login ===
ADMIN_PASSWORD=                            # Strong password untuk admin panel
